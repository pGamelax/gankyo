# ── Banco de dados ─────────────────────────────────────────────────────────────
# Connection string do container PostgreSQL interno na VPS
# Exemplo com container na mesma rede Docker:
DATABASE_URL=postgresql://usuario:senha@nome-do-container:5432/gankyo

# ── Backend ────────────────────────────────────────────────────────────────────
# Segredo para o Better Auth (mínimo 32 caracteres, aleatório)
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=troque_por_segredo_aleatorio_32chars

# URL pública do backend (sem barra no final)
BACKEND_URL=https://api.seudominio.com

# URL pública do frontend (usada pelo CORS do backend)
FRONTEND_URL=https://seudominio.com
