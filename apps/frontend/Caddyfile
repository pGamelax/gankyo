:3006 {
    root * /srv

    # SW e workbox: NUNCA cachear — browser precisa verificar atualizações sempre
    # No iOS isso é crítico: sw.js cacheado com immutable quebra o PWA offline
    @sw {
        path_regexp ^/(sw\.js|workbox-[^/]+\.js)$
    }
    header @sw Cache-Control "no-store, no-cache, must-revalidate"

    # Assets com hash no nome: cache imutável de 1 ano (exclui SW)
    @immutable {
        path *.js *.css *.woff2 *.woff *.ttf
        not path_regexp ^/(sw\.js|workbox-[^/]+\.js)$
    }
    header @immutable Cache-Control "public, max-age=31536000, immutable"

    # Manifest e ícones: cache curto
    @manifest path *.webmanifest *.ico *.svg *.png
    header @manifest Cache-Control "public, max-age=86400"

    encode gzip

    file_server

    # SPA fallback — rotas desconhecidas servem o index.html
    try_files {path} /index.html
}
